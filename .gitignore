# Secrets - never commit these
.env
*.key

# SQLite database - excluded by default per README setup note.
# Remove this line if you decide to commit the db itself instead.
*.db
*.sqlite
*.sqlite3

# Common Python/Node clutter if Claude Code adds either
__pycache__/
*.pyc
node_modules/
.venv/

# Run logs from ingest.py/classify.py - regenerable, noisy, not source
*.log

# Raw LLM response dumps saved for debugging (curator_agent.py,
# taxonomy_discovery.py) - the durable record is the db (taxonomy_proposals/
# curator_watchlist, or the reviewed taxonomy.json/schema.sql/classify_prompt.md
# edits), not these
*_last_response.txt
taxonomy_discovery_response.json
